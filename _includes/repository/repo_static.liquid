{% assign parts = include.repository | split: "/" %}
{% assign owner = parts[0] %}
{% assign name = parts[1] %}

<a href="https://github.com/{{ owner }}/{{ name }}" class="repo-static-card" target="_blank" rel="noopener">
  <div class="repo-static-card__inner">
    <div class="repo-static-card__title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 16 16" width="18" height="18" aria-hidden="true">
        <path fill="currentColor" d="M8 0C3.58 0 0 3.58 0 8a8 8 0 005.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82a7.42 7.42 0 014 0c1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.01 8.01 0 0016 8c0-4.42-3.58-8-8-8z"/>
      </svg>
      <span class="repo-static-card__name">{{ name }}</span>
    </div>
    <div class="repo-static-card__owner">{{ owner }}</div>
    <div class="repo-static-card__badges">
      <img src="https://img.shields.io/github/stars/{{ owner }}/{{ name }}?style=flat-square&label=stars&color=eaeaea&labelColor=24292e" alt="stars" loading="lazy">
      <img src="https://img.shields.io/github/forks/{{ owner }}/{{ name }}?style=flat-square&label=forks&color=eaeaea&labelColor=24292e" alt="forks" loading="lazy">
      <img src="https://img.shields.io/github/languages/top/{{ owner }}/{{ name }}?style=flat-square&color=2ea44f&labelColor=24292e" alt="language" loading="lazy">
    </div>
  </div>
</a>

<style>
.repo-static-card {
  display: block;
  padding: 1rem 1.25rem;
  border: 1px solid #d0d7de;
  border-radius: 6px;
  background: #fff;
  color: inherit;
  text-decoration: none !important;
  transition: border-color .15s ease, box-shadow .15s ease;
}
.repo-static-card:hover {
  border-color: #0969da;
  box-shadow: 0 2px 6px rgba(0,0,0,.06);
}
.repo-static-card__title {
  display: flex; align-items: center; gap: .4rem;
  font-weight: 600; font-size: 1rem; color: #0969da;
}
.repo-static-card__owner {
  font-size: .8rem; color: #57606a; margin-top: .15rem;
}
.repo-static-card__badges {
  margin-top: .6rem; display: flex; gap: .35rem; flex-wrap: wrap;
}
html[data-theme="dark"] .repo-static-card {
  background: #0d1117; border-color: #30363d;
}
html[data-theme="dark"] .repo-static-card__title { color: #58a6ff; }
html[data-theme="dark"] .repo-static-card__owner { color: #8b949e; }
</style>